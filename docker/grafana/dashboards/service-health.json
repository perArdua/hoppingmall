{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$service\"}[5m]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "(sum(rate(http_server_requests_seconds_count{job=~\"$service\",status=~\"5..\"}[5m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{job=~\"$service\"}[5m])) * 100", "legendFormat": "5xx %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }, "overrides": [] }
    },
    {
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=~\"$service\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=~\"$service\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=~\"$service\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Latency Heatmap",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum(increase(http_server_requests_seconds_bucket{job=~\"$service\"}[$__rate_interval])) by (le)", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "title": "JVM Heap (Used / Committed / Max)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{job}} used" },
        { "expr": "jvm_memory_committed_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{job}} committed" },
        { "expr": "jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"}", "legendFormat": "{{job}} max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "title": "GC Pause Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[5m])", "legendFormat": "{{job}} {{action}} {{cause}}" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Thread States",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [{ "expr": "jvm_threads_states_threads{job=~\"$service\"}", "legendFormat": "{{job}} {{state}}" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "hikaricp_connections_active{job=~\"$service\"}", "legendFormat": "{{job}} active" },
        { "expr": "hikaricp_connections{job=~\"$service\"}", "legendFormat": "{{job}} total" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "HikariCP Pending Threads",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [{ "expr": "hikaricp_connections_pending{job=~\"$service\"}", "legendFormat": "{{job}} pending" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        { "expr": "process_cpu_usage{job=~\"$service\"}", "legendFormat": "{{job}} process" },
        { "expr": "system_cpu_usage{job=~\"$service\"}", "legendFormat": "{{job}} system" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] }
    },
    {
      "title": "Log Stream",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [{ "expr": "{service=~\"$service\"} | json | line_format \"{{.level}} {{.message}}\"", "legendFormat": "" }],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [{ "queryType": "nativeSearch", "limit": 15, "serviceName": "$service" }],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "title": "Circuit Breaker State",
      "description": "Shows data only for services with resilience4j: payment, order, product, settlement. Other services show 'No Data' (expected).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [{ "expr": "resilience4j_circuitbreaker_state{job=~\"$service\"}", "legendFormat": "{{job}} {{name}} {{state}}" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "CLOSED" }, "1": { "text": "OPEN" }, "2": { "text": "HALF_OPEN" } } } ] }, "overrides": [] }
    },
    {
      "title": "Retry Calls (per min)",
      "description": "Shows data only for services with resilience4j: payment, order, product, settlement. Other services show 'No Data' (expected).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "expr": "rate(resilience4j_retry_calls_total{job=~\"$service\",kind=\"successful_without_retry\"}[5m]) * 60", "legendFormat": "{{job}} {{name}} success (no retry)" },
        { "expr": "rate(resilience4j_retry_calls_total{job=~\"$service\",kind=\"successful_with_retry\"}[5m]) * 60", "legendFormat": "{{job}} {{name}} success (with retry)" },
        { "expr": "rate(resilience4j_retry_calls_total{job=~\"$service\",kind=\"failed_with_retry\"}[5m]) * 60", "legendFormat": "{{job}} {{name}} failed" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqpm" }, "overrides": [] }
    }
  ],
  "schemaVersion": 39,
  "tags": ["service-health"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(up, job)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values(up, job)",
        "type": "query",
        "refresh": 2
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Service Health Dashboard",
  "uid": "service-health"
}
