      "targets": [{ "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"4..\"}[5m])) / sum by (job) (rate(http_server_requests_seconds_count[5m])) * 100", "legendFormat": "{{job}}" }],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
